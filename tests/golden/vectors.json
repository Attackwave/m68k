        "IDENT:L",
        "IDENT:D0",
        "PUNCT:,",
        "IDENT:D1"
      ]
    },
    {
      "name": "token_'$FF'",
      "input": "$FF",
      "expected_tokens": [
        "NUM:$FF"
      ]
    },
    {
      "name": "token_'42'",
      "input": "42",
      "expected_tokens": [
        "NUM:42"
      ]
    },
    {
      "name": "token_'%1010'",
      "input": "%1010",
      "expected_tokens": [
        "BIN:%1010"
      ]
    },
    {
      "name": "token_\"'A'\"",
      "input": "'A'",
      "expected_tokens": [
        "CHAR:'A'"
      ]
    },
    {
      "name": "token_'move.l_#$1234,d0'",
      "input": "move.l #$1234,d0",
      "expected_tokens": [
